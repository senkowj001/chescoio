# =============================================================================
# chescoio environment variables
# =============================================================================
# Copy to .env for local dev. NEVER commit .env to version control.

# -----------------------------------------------------------------------------
# Django core
# -----------------------------------------------------------------------------

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-local-dev-only-change-in-production

# True for local dev, False for production (set in Heroku config vars)
DEBUG=True

# Local default; in Heroku, set this to chescoio.settings.production
DJANGO_SETTINGS_MODULE=chescoio.settings.local


# -----------------------------------------------------------------------------
# Database (local dev only — Heroku sets DATABASE_URL automatically)
# -----------------------------------------------------------------------------
# Default is sqlite for zero-config local dev. To use local Postgres, uncomment:
# DATABASE_URL=postgres://chescoio:password@localhost:5432/chescoio


# -----------------------------------------------------------------------------
# Email (production — Hostinger SMTP, mirrors HuntScrape)
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=hello@chesco.io
SERVER_EMAIL=hello@chesco.io


# -----------------------------------------------------------------------------
# Printify (Sprint 2+)
# -----------------------------------------------------------------------------
PRINTIFY_ACCESS_TOKEN=
PRINTIFY_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# Stripe (Sprint 3+)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# Heroku app metadata (set automatically in Heroku, harmless locally)
# -----------------------------------------------------------------------------
# HEROKU_APP_NAME=chescoio
